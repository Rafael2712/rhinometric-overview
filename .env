# SSL Configuration (for production)
SSL_EMAIL=admin@rhinometric.com

# License System
LICENSE_ENCRYPTION_KEY=your_license_encryption_key_32_chars

# Redis Configuration
REDIS_PASSWORD=redis_secure_password

# Environment
ENVIRONMENT=production
DEBUG=false