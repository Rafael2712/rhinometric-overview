{
  "dashboard": {
    "title": "AI Anomaly Detection",
    "uid": "rhinometric-ai-anomalies",
    "tags": ["rhinometric", "ai", "anomaly"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "type": "stat",
        "title": "Total Detectadas (24h)",
        "targets": [
          {
            "expr": "increase(rhinometric_anomaly_detections_total[24h])",
            "refId": "A",
            "datasource": { "uid": "prometheus" }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 10, "color": "yellow" },
                { "value": 50, "color": "red" }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 2,
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "type": "stat",
        "title": "Anomalías Activas",
        "targets": [
          {
            "expr": "rhinometric_anomaly_active_count",
            "refId": "A",
            "datasource": { "uid": "prometheus" }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "yellow" },
                { "value": 5, "color": "red" }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "type": "stat",
        "title": "Modelos ML Entrenados",
        "targets": [
          {
            "expr": "rhinometric_anomaly_models_trained",
            "refId": "A",
            "datasource": { "uid": "prometheus" }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        }
      },
      {
        "id": 4,
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "type": "stat",
        "title": "Tasa de Detección (5m)",
        "targets": [
          {
            "expr": "rate(rhinometric_anomaly_detections_total[5m])",
            "refId": "A",
            "datasource": { "uid": "prometheus" }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "ops",
            "decimals": 2
          }
        }
      },
      {
        "id": 5,
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "type": "timeseries",
        "title": "Detecciones en el Tiempo",
        "targets": [
          {
            "expr": "rate(rhinometric_anomaly_detections_total[1m])",
            "refId": "A",
            "legendFormat": "Tasa de Detección",
            "datasource": { "uid": "prometheus" }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "showPoints": "auto"
            },
            "unit": "ops"
          }
        }
      },
      {
        "id": 6,
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "type": "timeseries",
        "title": "Anomalías Activas por Tipo",
        "targets": [
          {
            "expr": "rhinometric_anomaly_active_count by (anomaly_type)",
            "refId": "A",
            "legendFormat": "{{anomaly_type}}",
            "datasource": { "uid": "prometheus" }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 20,
              "showPoints": "auto",
              "stacking": { "mode": "normal" }
            },
            "unit": "short"
          }
        }
      }
    ]
  },
  "overwrite": true
}
