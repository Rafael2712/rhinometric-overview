# ============================================
# RHINOMETRIC v2.5.0 - Production Environment
# ============================================
# IMPORTANTE: Copiar a .env.prod y completar con valores reales
# NO SUBIR .env.prod A GIT

# ============================================
# DOMINIO Y RED
# ============================================
DOMAIN=observa.miempresa.com
# Subdominio para Grafana (opcional)
GRAFANA_SUBDOMAIN=grafana.miempresa.com

# ============================================
# GRAFANA
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_STRONG_PASSWORD_HERE

# Seguridad Grafana
GF_SERVER_PROTOCOL=https
GF_SERVER_DOMAIN=${DOMAIN}
GF_SERVER_ROOT_URL=https://${DOMAIN}
GF_SECURITY_ADMIN_USER=${GRAFANA_ADMIN_USER}
GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}
GF_SECURITY_COOKIE_SECURE=true
GF_SECURITY_COOKIE_SAMESITE=strict
GF_AUTH_DISABLE_SIGNOUT_MENU=false
GF_USERS_ALLOW_SIGN_UP=false
GF_USERS_ALLOW_ORG_CREATE=false
GF_AUTH_ANONYMOUS_ENABLED=false
GF_SECURITY_ALLOW_EMBEDDING=false

# ============================================
# SMTP PARA ALERTAS Y REPORTES
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=reportes@miempresa.com
SMTP_PASSWORD=CHANGEME_APP_PASSWORD_HERE
SMTP_FROM=reportes@miempresa.com
SMTP_FROM_NAME=Rhinometric Observability

# Alertmanager SMTP
ALERTMANAGER_SMTP_FROM=${SMTP_FROM}
ALERTMANAGER_SMTP_TO=ops@miempresa.com,devops@miempresa.com

# ============================================
# JWT SECRETS (Generar con: openssl rand -base64 32)
# ============================================
DASHBUILDER_JWT_SECRET=CHANGEME_GENERATE_WITH_OPENSSL
REPORTGEN_JWT_SECRET=CHANGEME_GENERATE_WITH_OPENSSL
AI_JWT_SECRET=CHANGEME_GENERATE_WITH_OPENSSL
LICENSE_JWT_SECRET=CHANGEME_GENERATE_WITH_OPENSSL

# ============================================
# BASE DE DATOS
# ============================================
POSTGRES_USER=rhinometric
POSTGRES_PASSWORD=CHANGEME_STRONG_DB_PASSWORD
POSTGRES_DB=rhinometric_prod
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

REDIS_PASSWORD=CHANGEME_STRONG_REDIS_PASSWORD

# ============================================
# SEGURIDAD APIs
# ============================================
# Deshabilitar /docs en producción
ENABLE_DOCS=false

# CORS - Solo dominios permitidos (separados por coma)
ALLOWED_ORIGINS=https://${DOMAIN},https://${GRAFANA_SUBDOMAIN}

# Rate limiting
API_RATE_LIMIT=100/minute
API_BURST_LIMIT=20

# ============================================
# RETENCIÓN DE DATOS
# ============================================
# Prometheus
PROM_RETENTION_TIME=15d
PROM_RETENTION_SIZE=10GB

# Loki
LOKI_RETENTION_PERIOD=7d
LOKI_RETENTION_SIZE=5GB

# Tempo
TEMPO_RETENTION_PERIOD=3d

# Docker logs
DOCKER_LOG_MAX_SIZE=50m
DOCKER_LOG_MAX_FILE=5

# ============================================
# RECURSOS (Límites por servicio)
# ============================================
# Grafana
GRAFANA_MEM_LIMIT=1g
GRAFANA_CPU_LIMIT=1.0

# Prometheus
PROMETHEUS_MEM_LIMIT=2g
PROMETHEUS_CPU_LIMIT=2.0

# Loki
LOKI_MEM_LIMIT=1g
LOKI_CPU_LIMIT=1.0

# FastAPI services
API_MEM_LIMIT=512m
API_CPU_LIMIT=0.5
API_WORKERS=2

# ============================================
# TLS/SSL
# ============================================
# Traefik
TRAEFIK_ACME_EMAIL=admin@miempresa.com
TRAEFIK_LOG_LEVEL=INFO

# Certificados (si usas custom certs en lugar de Let's Encrypt)
TLS_CERT_PATH=/certs/cert.pem
TLS_KEY_PATH=/certs/key.pem

# ============================================
# LICENCIAMIENTO
# ============================================
LICENSE_DURATION_DAYS=180
LICENSE_SERVER_URL=http://rhinometric-license-server:8090

# ============================================
# MONITOREO Y ALERTAS
# ============================================
# Umbrales de alertas
ALERT_DISK_WARNING=80
ALERT_DISK_CRITICAL=90
ALERT_MEM_WARNING=85
ALERT_MEM_CRITICAL=95
ALERT_CPU_WARNING=80
ALERT_CPU_CRITICAL=90

# Scrape intervals
SCRAPE_INTERVAL=30s
SCRAPE_TIMEOUT=10s

# ============================================
# BACKUPS
# ============================================
BACKUP_DIR=/var/backups/rhinometric
BACKUP_RETENTION_DAYS=30
BACKUP_TIME=02:00

# ============================================
# ADICIONALES
# ============================================
# Timezone
TZ=America/New_York

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Versión
RHINOMETRIC_VERSION=2.5.0
