{
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "50m",
    "max-file": "5",
    "labels": "production",
    "env": "ENVIRONMENT"
  },
  "storage-driver": "overlay2",
  "default-address-pools": [
    {
      "base": "172.20.0.0/16",
      "size": 24
    }
  ],
  "log-level": "info",
  "metrics-addr": "0.0.0.0:9323",
  "experimental": false,
  "features": {
    "buildkit": true
  }
}
