            "templating": {"list": []},
            "time": {"from": "now-1h", "to": "now"},
            "timepicker": {},
            "timezone": "",
            "title": f"RHINOMETRIC - {name} MQTT Monitoring",
            "uid": uid,
            "version": 0,
            "weekStart": ""
