# Rhinometric v2.1.0 - Environment Configuration Template
# Copy this file to .env and configure with your actual values

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_USER=rhinometric
POSTGRES_DB=rhinometric_trial

# ═══════════════════════════════════════════════════════════════════════════
# CACHE/REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
REDIS_PASSWORD=your_secure_redis_password_here

# ═══════════════════════════════════════════════════════════════════════════
# GRAFANA CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_password_on_first_login

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL/SMTP CONFIGURATION (for License Management)
# ═══════════════════════════════════════════════════════════════════════════
# Configure with your email provider
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_USER=your_email@yourdomain.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@yourdomain.com

# IMPORTANT: Use app-specific passwords, not your main account password
# Zoho: https://accounts.zoho.com/home#security/security → App Passwords
# Gmail: https://myaccount.google.com/apppasswords

# ═══════════════════════════════════════════════════════════════════════════
# SYSTEM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
HOME=$HOME
RHINOMETRIC_MODE=trial

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY WARNINGS
# ═══════════════════════════════════════════════════════════════════════════
# ⚠️  NEVER commit .env with real credentials to version control
# ⚠️  Use strong, unique passwords for production deployments
# ⚠️  Change ALL default passwords immediately after installation
# ⚠️  Use application-specific passwords for SMTP (not your main password)
# ⚠️  Set file permissions: chmod 600 .env
