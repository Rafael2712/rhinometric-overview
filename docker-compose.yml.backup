version: '3.8'

services:
  # BASE DE DATOS - Sin dependencias
  db:
    image: postgres:15
    container_name: mi-proyecto-db-1
    environment:
      POSTGRES_DB: rhinometric
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: secure_password_123
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    networks:
      - rhinometric_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U admin -d rhinometric"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  # PGBOUNCER - Solo depende de DB
  pgbouncer:
    image: pgbouncer/pgbouncer:latest
    container_name: mi-proyecto-pgbouncer-1
    environment:
      DATABASES_HOST: db
      DATABASES_PORT: 5432
      DATABASES_USER: admin
      DATABASES_PASSWORD: secure_password_123
      DATABASES_DBNAME: rhinometric
      POOL_MODE: transaction
    ports:
      - "6432:6432"
    depends_on:
      db:
        condition: service_healthy
    networks:
      - rhinometric_network
    restart: unless-stopped

  # LICENSE SERVER - Sin healthcheck por ahora
  license-server:
    build:
      context: .
      dockerfile: Dockerfile-license-server
    container_name: mi-proyecto-license-server
    ports:
      - "5000:5000"
    volumes:
      - license_data:/data
    environment:
      - PYTHONUNBUFFERED=1
    networks:
      - rhinometric_network
    restart: unless-stopped

  # TRAEFIK v2.10 (compatible)
  traefik:
    image: traefik:v2.10
    container_name: mi-proyecto-traefik-1
    command:
      - "--api.insecure=true"
      - "--providers.docker=true"
      - "--entrypoints.web.address=:80"
    ports:
      - "8082:80"
      - "8080:8080"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - rhinometric_network
    restart: unless-stopped

  # WEB con nginx.conf corregido
  web:
    image: nginx:alpine
    container_name: mi-proyecto-web-1
    volumes:
      - ./html:/usr/share/nginx/html:ro
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    networks:
      - rhinometric_network
    restart: unless-stopped

  # PROMETHEUS
  prometheus:
    image: prom/prometheus:latest
    container_name: mi-proyecto-prometheus-1
    ports:
      - "9090:9090"
    volumes:
      - prometheus_data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
    networks:
      - rhinometric_network
    restart: unless-stopped

  # ALERTMANAGER
  alertmanager:
    image: prom/alertmanager:latest
    container_name: mi-proyecto-alertmanager-1
    ports:
      - "9093:9093"
    volumes:
      - alertmanager_data:/alertmanager
    networks:
      - rhinometric_network
    restart: unless-stopped

  # GRAFANA
  grafana:
    image: grafana/grafana:latest
    container_name: mi-proyecto-grafana-1
    ports:
      - "3002:3000"
    environment:
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD=admin123
    volumes:
      - grafana_data:/var/lib/grafana
    networks:
      - rhinometric_network
    restart: unless-stopped

  # LOKI
  loki:
    image: grafana/loki:2.9.0
    container_name: mi-proyecto-loki
    ports:
      - "3100:3100"
    volumes:
      - loki_data:/loki
    networks:
      - rhinometric_network
    restart: unless-stopped

  # PROMTAIL
  promtail:
    image: grafana/promtail:2.9.0
    container_name: mi-proyecto-promtail-1
    volumes:
      - /var/log:/var/log:ro
    networks:
      - rhinometric_network
    restart: unless-stopped

  # EXPORTERS
  node-exporter:
    image: prom/node-exporter:latest
    container_name: mi-proyecto-node-exporter-1
    ports:
      - "9100:9100"
    networks:
      - rhinometric_network
    restart: unless-stopped

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.47.2
    container_name: mi-proyecto-cadvisor-1
    ports:
      - "8081:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
    privileged: true
    networks:
      - rhinometric_network
    restart: unless-stopped

  blackbox-exporter:
    image: prom/blackbox-exporter:latest
    container_name: mi-proyecto-blackbox-exporter-1
    ports:
      - "9115:9115"
    networks:
      - rhinometric_network
    restart: unless-stopped

  postgres-exporter:
    image: prometheuscommunity/postgres-exporter:latest
    container_name: mi-proyecto-postgres-exporter-1
    ports:
      - "9187:9187"
    environment:
      DATA_SOURCE_NAME: "postgresql://admin:secure_password_123@db:5432/rhinometric?sslmode=disable"
    depends_on:
      - db
    networks:
      - rhinometric_network
    restart: unless-stopped

  nginx-exporter:
    image: nginx/nginx-prometheus-exporter:latest
    container_name: mi-proyecto-nginx-exporter-1
    ports:
      - "9113:9113"
    command:
      - -nginx.scrape-uri=http://mi-proyecto-web-1/nginx_status
    depends_on:
      - web
    networks:
      - rhinometric_network
    restart: unless-stopped

  pgbouncer-exporter:
    image: prometheuscommunity/pgbouncer-exporter:latest
    container_name: mi-proyecto-pgbouncer-exporter-1
    ports:
      - "9127:9127"
    depends_on:
      - pgbouncer
    networks:
      - rhinometric_network
    restart: unless-stopped

networks:
  rhinometric_network:
    driver: bridge

volumes:
  postgres_data:
  prometheus_data:
  grafana_data:
  alertmanager_data:
  loki_data:
  license_data: