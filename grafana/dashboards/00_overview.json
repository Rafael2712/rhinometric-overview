{
  "id": null,
  "title": "Observability - Overview",
  "uid": "overview-obs",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Targets UP (Prometheus)",
      "id": 1,
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets":[{"expr":"sum(up)"}]
    },
    {
      "type": "timeseries",
      "title": "Requests (logs) por minuto",
      "id": 2,
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 0},
      "targets":[
        {"datasource":{"type":"loki","uid":"loki"},
         "expr":"sum(rate({job=~\".+\"}[1m]))"}
      ]
    },
    {
      "type": "table",
      "title": "Errores recientes (Loki)",
      "id": 3,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "targets":[
        {"datasource":{"type":"loki","uid":"loki"},
         "expr":"{level=~\"error|ERROR|ERR\"} | line_format \"{{ .container }}: {{ .message }}\"",
         "legendFormat": "{{container}}"}
      ],
      "options":{"showHeader": true}
    }
  ]
}
