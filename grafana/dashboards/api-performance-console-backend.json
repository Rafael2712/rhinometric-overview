{
  "dashboard": {
    "title": "API Performance – Console Backend",
    "uid": "api-performance-console-backend",
    "tags": ["api", "http", "console-backend", "rhinometric"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate (QPS) by Endpoint",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [{
          "expr": "sum(rate(http_requests_total{job=\"console-backend\"}[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {"drawStyle": "line", "fillOpacity": 10}
          }
        }
      },
      {
        "id": 2,
        "title": "HTTP Error Rate (%)",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [{
          "expr": "100 * sum(rate(http_requests_total{job=\"console-backend\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"console-backend\"}[5m]))",
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 3, "color": "orange"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Total Requests (5m)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 3, "x": 18, "y": 0},
        "targets": [{
          "expr": "sum(increase(http_requests_total{job=\"console-backend\"}[5m]))",
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {"unit": "short"}
        }
      },
      {
        "id": 4,
        "title": "In Progress",
        "type": "stat",
        "gridPos": {"h": 4, "w": 3, "x": 21, "y": 0},
        "targets": [{
          "expr": "sum(http_requests_in_progress{job=\"console-backend\"})",
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Requests by Status Code",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [{
          "expr": "sum(rate(http_requests_total{job=\"console-backend\"}[1m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {"drawStyle": "line", "fillOpacity": 50, "stacking": {"mode": "normal"}}
          },
          "overrides": [
            {"matcher": {"id": "byRegexp", "options": "2.."}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
            {"matcher": {"id": "byRegexp", "options": "4.."}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
            {"matcher": {"id": "byRegexp", "options": "5.."}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
          ]
        }
      },
      {
        "id": 6,
        "title": "HTTP Latency Percentiles (p50/p95/p99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"console-backend\"}[5m])))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"console-backend\"}[5m])))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"console-backend\"}[5m])))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "s"},
          "overrides": [
            {"matcher": {"id": "byName", "options": "p50"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
            {"matcher": {"id": "byName", "options": "p95"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
            {"matcher": {"id": "byName", "options": "p99"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
          ]
        },
        "options": {
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      },
      {
        "id": 7,
        "title": "Top Slowest Endpoints",
        "type": "table",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "targets": [{
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket{job=\"console-backend\"}[5m]))))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }],
        "transformations": [
          {"id": "organize", "options": {"excludeByName": {"Time": true, "le": true}, "renameByName": {"Value": "P95 Latency (s)", "endpoint": "Endpoint"}}}
        ],
        "fieldConfig": {
          "overrides": [
            {"matcher": {"id": "byName", "options": "P95 Latency (s)"}, "properties": [{"id": "unit", "value": "s"}, {"id": "custom.cellOptions", "value": {"type": "color-background"}}]}
          ]
        }
      },
      {
        "id": 8,
        "title": "HTTP Request/Response Size (P95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_size_bytes_bucket{job=\"console-backend\"}[5m])))",
            "legendFormat": "Request",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum by (le) (rate(http_response_size_bytes_bucket{job=\"console-backend\"}[5m])))",
            "legendFormat": "Response",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "bytes"}
        }
      },
      {
        "id": 9,
        "title": "DB Connection Pool",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
        "targets": [
          {
            "expr": "db_connections_active{job=\"console-backend\"}",
            "legendFormat": "Active",
            "refId": "A"
          },
          {
            "expr": "db_connections_idle{job=\"console-backend\"}",
            "legendFormat": "Idle",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {"drawStyle": "line", "fillOpacity": 50, "stacking": {"mode": "normal"}}
          }
        }
      }
    ]
  },
  "overwrite": true
}
