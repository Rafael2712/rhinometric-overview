          "editorMode": "code",
          "exemplar": false,
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket{job=\"console-backend\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (endpoint) (rate(http_requests_total{job=\"console-backend\"}[5m]))",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "B"
        }
      ],
      "title": "Top Slowest Endpoints",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "endpoint",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "component": true,
              "instance": true,
              "job": true,
              "service": true,
              "tier": true
            },
            "includeByName": {},
            "indexByName": {
              "endpoint": 0,
              "Value #A": 1,
              "Value #B": 2
            },
            "renameByName": {
              "Value #A": "P95 Latency",
              "Value #B": "QPS",
              "endpoint": "Endpoint"
            }
          }
        }
      ],
      "type": "table"
