      {
        "id": 9,
        "title": "Active Alerts by Service",
        "type": "table",
        "targets": [
          {
            "expr": "ALERTS{alertstate=\"firing\",job=~\"prometheus|alertmanager|grafana|loki|jaeger|ai-anomaly|rhinometric-console-backend|license-validator\"}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
        "options": {
          "showHeader": true,
          "footer": {
            "show": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "filterable": true
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "alertname"},
              "properties": [
                {"id": "displayName", "value": "Alert Name"},
                {"id": "custom.width", "value": 200}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "severity"},
              "properties": [
                {"id": "displayName", "value": "Severity"},
                {"id": "custom.width", "value": 100}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "job"},
              "properties": [
                {"id": "displayName", "value": "Component"},
                {"id": "custom.width", "value": 180}
              ]
            }
          ]
        }
