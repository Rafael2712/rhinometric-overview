{
  "id": null,
  "uid": "obs-overview",
  "title": "Observability - Overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Targets UP (Prometheus)",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"refId":"A","expr":"sum(up)"}]
    },
    {
      "type": "stat",
      "title": "Probes OK (Blackbox)",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [{"refId":"A","expr":"sum(probe_success)"}]
    },
    {
      "type": "timeseries",
      "title": "Latencia (Blackbox) media 5m",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "targets":[{"refId":"A","expr":"avg_over_time(probe_duration_seconds[5m])"}]
    },
    {
      "type": "stat",
      "title": "Tasa de errores (logs/min)",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 6},
      "targets":[
        {
          "refId":"A",
          "datasource": { "type":"loki", "uid":"fey5fwke7h4hsd" },
          "expr":"(sum(rate({}|= \"error\"[1m])) or vector(0))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Eventos de log/min (Total)",
      "gridPos": {"h": 6, "w": 18, "x": 6, "y": 6},
      "targets":[
        {
          "refId":"A",
          "datasource": { "type":"loki", "uid":"fey5fwke7h4hsd" },
          "expr":"(sum(rate({}[1m])) or vector(0))"
        }
      ]
    }
  ]
}
