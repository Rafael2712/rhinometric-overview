  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [{"title": "← Overview", "url": "/d/rhinometric-overview?from=$__from&to=$__to", "type": "link", "icon": "dashboard"}, {"title": "→ Docker Containers", "url": "/d/docker-containers?from=$__from&to=$__to", "type": "link", "icon": "external link"}, {"title": "→ AI Anomaly", "url": "/d/ai-anomaly?from=$__from&to=$__to", "type": "link", "icon": "external link"}],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "Total CPU",
          "refId": "A"
        },
        {
          "expr": "100 - (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]) * 100)",
          "legendFormat": "CPU {{cpu}}",
          "refId": "B"
        }
      ],
      "title": "💻 CPU Usage per Core",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20},
          "unit": "decbytes"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used",
          "refId": "B"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available",
          "refId": "C"
        },
        {
          "expr": "node_memory_Cached_bytes + node_memory_Buffers_bytes",
          "legendFormat": "Cached + Buffers",
          "refId": "D"
        }
      ],
      "title": "🧠 Memory Usage Breakdown",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 100,
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 85}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 3,
      "options": {"orientation": "auto", "showThresholdMarkers": true},
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/mnt/host/c\"} / node_filesystem_size_bytes{mountpoint=\"/mnt/host/c\"}) * 100)",
          "refId": "A"
        }
      ],
      "title": "💿 Root Filesystem Usage",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20},
          "unit": "iops"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "rate(node_disk_reads_completed_total[5m])",
          "legendFormat": "Reads {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_writes_completed_total[5m])",
          "legendFormat": "Writes {{device}}",
          "refId": "B"
        }
      ],
      "title": "💾 Disk I/O Operations",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20},
          "unit": "Bps"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "/Receive/"},
            "properties": [{"id": "custom.transform", "value": "negative-Y"}]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 5,
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "Receive {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "Transmit {{device}}",
          "refId": "B"
        }
      ],
      "title": "🌐 Network Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"cellOptions": {"type": "auto"}},
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Load 1m"},
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {"mode": "gradient", "type": "gauge"}
              },
              {"id": "max", "value": 10}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 6,
      "options": {"showHeader": true},
      "targets": [
        {
          "expr": "node_load1",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "📊 System Load Average",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {"Value": "Load 1m"}
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 7,
      "targets": [
        {
          "expr": "node_filefd_allocated",
          "legendFormat": "Allocated File Descriptors",
          "refId": "A"
        },
        {
          "expr": "node_filefd_maximum",
          "legendFormat": "Maximum File Descriptors",
          "refId": "B"
        }
      ],
      "title": "📁 File Descriptors",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "id": 8,
      "targets": [
        {
          "expr": "rate(node_context_switches_total[5m])",
          "legendFormat": "Context Switches",
          "refId": "A"
        },
        {
          "expr": "rate(node_intr_total[5m])",
          "legendFormat": "Interrupts",
          "refId": "B"
        }
      ],
      "title": "⚡ System Context Switches & Interrupts",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["rhinometric", "system"],
