FROM python:3.9-slim

WORKDIR /app

# Copiar validador
COPY security/licensing/license_validator.py /app/validator.py

# Instalar Grafana, Prometheus y Loki básicos
RUN apt-get update && apt-get install -y \
    curl \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

# Script de entrada
COPY entrypoint-mvp.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3000

ENTRYPOINT ["/entrypoint.sh"]
