{
  "dashboard": {
    "title": "🔎 Blackbox Exporter - Endpoint Monitoring",
    "tags": ["blackbox", "endpoints", "monitoring", "enterprise"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {"id": 1, "title": "✅ Probe Success Rate", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "avg_over_time(probe_success[5m])", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 0.95, "color": "yellow"}, {"value": 0.99, "color": "green"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 2, "title": "⏱️ Probe Duration", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "avg(probe_duration_seconds)", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 0.5, "color": "yellow"}, {"value": 2, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 3, "title": "🔒 SSL Cert Expiry", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "d", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 7, "color": "yellow"}, {"value": 30, "color": "green"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 4, "title": "🌐 HTTP Status Code", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_http_status_code", "refId": "A"}], "fieldConfig": {"defaults": {"mappings": [{"type": "value", "value": 200, "text": "200 OK", "color": "green"}, {"type": "range", "from": 400, "to": 499, "text": "4xx", "color": "yellow"}, {"type": "range", "from": 500, "to": 599, "text": "5xx", "color": "red"}], "color": {"mode": "thresholds"}}}, "options": {"graphMode": "none", "colorMode": "background"}},
      {"id": 5, "title": "📊 Probe Success Over Time", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_success", "legendFormat": "{{instance}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1, "custom": {"drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 50}}}},
      {"id": 6, "title": "⏱️ Response Time", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_duration_seconds", "legendFormat": "{{instance}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}}}},
      {"id": 7, "title": "🔍 DNS Lookup Time", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_dns_lookup_time_seconds", "legendFormat": "DNS Lookup", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}}}},
      {"id": 8, "title": "🌐 HTTP Phases", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_http_duration_seconds{phase=\"resolve\"}", "legendFormat": "DNS", "refId": "A"}, {"expr": "probe_http_duration_seconds{phase=\"connect\"}", "legendFormat": "Connect", "refId": "B"}, {"expr": "probe_http_duration_seconds{phase=\"tls\"}", "legendFormat": "TLS", "refId": "C"}, {"expr": "probe_http_duration_seconds{phase=\"processing\"}", "legendFormat": "Processing", "refId": "D"}, {"expr": "probe_http_duration_seconds{phase=\"transfer\"}", "legendFormat": "Transfer", "refId": "E"}], "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}}}}
    ]
  },
  "overwrite": true
}
