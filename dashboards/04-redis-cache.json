{
  "dashboard": {
    "title": "⚡ Redis - Cache Performance",
    "tags": ["redis", "cache", "performance", "enterprise"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {"id": 1, "title": "💾 Memory Usage", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "redis_memory_used_bytes", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 200000000, "color": "yellow"}, {"value": 250000000, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 2, "title": "⚡ Commands/sec", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(rate(redis_commands_total[5m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 3, "title": "🔑 Total Keys", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(redis_db_keys)", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 4, "title": "👥 Connected Clients", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "redis_connected_clients", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 5, "title": "📈 Commands Rate", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(rate(redis_commands_total[5m])) by (cmd)", "legendFormat": "{{cmd}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}}}},
      {"id": 6, "title": "💾 Memory Usage Over Time", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "redis_memory_used_bytes", "legendFormat": "Used", "refId": "A"}, {"expr": "redis_memory_max_bytes", "legendFormat": "Max", "refId": "B"}], "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}}}},
      {"id": 7, "title": "🔄 Evicted Keys", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 0, "y": 14}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "redis_evicted_keys_total", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 100, "color": "yellow"}, {"value": 1000, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 8, "title": "📊 Keyspace Distribution", "type": "piechart", "gridPos": {"h": 6, "w": 6, "x": 6, "y": 14}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "redis_db_keys", "legendFormat": "db{{db}}", "refId": "A"}], "options": {"legend": {"displayMode": "table", "placement": "right"}, "pieType": "donut"}},
      {"id": 9, "title": "🔢 Uptime", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 12, "y": 14}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "redis_uptime_in_seconds", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "none", "colorMode": "value"}}
    ]
  },
  "overwrite": true
}
