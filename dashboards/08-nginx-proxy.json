{
  "dashboard": {
    "title": "🌐 Nginx - Proxy Dashboard",
    "tags": ["nginx", "proxy", "web", "enterprise"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {"id": 1, "title": "🎯 Uptime Status", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "up{job=\"blackbox\"}", "refId": "A"}], "fieldConfig": {"defaults": {"mappings": [{"type": "value", "value": 0, "text": "DOWN", "color": "red"}, {"type": "value", "value": 1, "text": "UP", "color": "green"}], "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 1, "color": "green"}]}}}, "options": {"graphMode": "none", "colorMode": "background", "textMode": "value"}},
      {"id": 2, "title": "⏱️ Response Time", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_duration_seconds{job=\"blackbox\"}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 0.5, "color": "yellow"}, {"value": 2, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 3, "title": "✅ Probe Success", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_success{job=\"blackbox\"}", "refId": "A"}], "fieldConfig": {"defaults": {"mappings": [{"type": "value", "value": 0, "text": "FAIL", "color": "red"}, {"type": "value", "value": 1, "text": "SUCCESS", "color": "green"}], "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 1, "color": "green"}]}}}, "options": {"graphMode": "none", "colorMode": "background"}},
      {"id": 4, "title": "🔒 SSL Expiry", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox\"} - time()) / 86400", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "d", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 7, "color": "yellow"}, {"value": 30, "color": "green"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 5, "title": "⏱️ Response Time Over Time", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_duration_seconds{job=\"blackbox\"}", "legendFormat": "Response Time", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}}}},
      {"id": 6, "title": "✅ Probe Success Rate", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "avg_over_time(probe_success{job=\"blackbox\"}[5m])", "legendFormat": "Success Rate", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 30}}}},
      {"id": 7, "title": "🌐 HTTP Status Codes", "type": "stat", "gridPos": {"h": 6, "w": 12, "x": 0, "y": 14}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_http_status_code{job=\"blackbox\"}", "refId": "A"}], "fieldConfig": {"defaults": {"mappings": [{"type": "value", "value": 200, "text": "200 OK", "color": "green"}, {"type": "range", "from": 400, "to": 499, "text": "4xx ERROR", "color": "yellow"}, {"type": "range", "from": 500, "to": 599, "text": "5xx ERROR", "color": "red"}], "color": {"mode": "thresholds"}}}, "options": {"graphMode": "none", "colorMode": "background"}},
      {"id": 8, "title": "🔍 DNS Lookup Duration", "type": "timeseries", "gridPos": {"h": 6, "w": 12, "x": 12, "y": 14}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "probe_dns_lookup_time_seconds{job=\"blackbox\"}", "legendFormat": "DNS Lookup", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}}}}
    ]
  },
  "overwrite": true
}
