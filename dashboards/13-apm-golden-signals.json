{
  "dashboard": {
    "title": "🎯 APM - Application Performance Monitoring",
    "tags": ["apm", "performance", "golden-signals", "enterprise"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {"id": 1, "title": "⚡ Latency - p50", "type": "stat", "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "histogram_quantile(0.50, sum(rate(tempo_request_duration_seconds_bucket[5m])) by (le))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 0.5, "color": "yellow"}, {"value": 1, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 2, "title": "⚡ Latency - p95", "type": "stat", "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "histogram_quantile(0.95, sum(rate(tempo_request_duration_seconds_bucket[5m])) by (le))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 2, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 3, "title": "⚡ Latency - p99", "type": "stat", "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "histogram_quantile(0.99, sum(rate(tempo_request_duration_seconds_bucket[5m])) by (le))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 2, "color": "yellow"}, {"value": 5, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 4, "title": "🚀 Traffic (RPS)", "type": "stat", "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(rate(tempo_request_message_bytes_count[5m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 5, "title": "❌ Error Rate", "type": "stat", "gridPos": {"h": 5, "w": 6, "x": 0, "y": 5}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "(sum(rate(tempo_request_message_bytes_count{status_code!=\"200\"}[5m])) / sum(rate(tempo_request_message_bytes_count[5m]))) * 100", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 5, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 6, "title": "📊 Saturation - CPU", "type": "stat", "gridPos": {"h": 5, "w": 6, "x": 6, "y": 5}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 70, "color": "yellow"}, {"value": 90, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 7, "title": "📊 Saturation - Memory", "type": "stat", "gridPos": {"h": 5, "w": 6, "x": 12, "y": 5}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 70, "color": "yellow"}, {"value": 90, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 8, "title": "📊 Saturation - Disk", "type": "stat", "gridPos": {"h": 5, "w": 6, "x": 18, "y": 5}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "(1 - (node_filesystem_avail_bytes{fstype!=\"tmpfs\"} / node_filesystem_size_bytes{fstype!=\"tmpfs\"})) * 100", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 70, "color": "yellow"}, {"value": 90, "color": "red"}]}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 9, "title": "⏱️ Latency Percentiles", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "histogram_quantile(0.50, sum(rate(tempo_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A"}, {"expr": "histogram_quantile(0.95, sum(rate(tempo_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B"}, {"expr": "histogram_quantile(0.99, sum(rate(tempo_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C"}], "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}}}},
      {"id": 10, "title": "🚀 Traffic by Endpoint", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(rate(tempo_request_message_bytes_count[5m])) by (route)", "legendFormat": "{{route}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}}}},
      {"id": 11, "title": "❌ Error Rate Over Time", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(rate(tempo_request_message_bytes_count{status_code!=\"200\"}[5m])) by (status_code)", "legendFormat": "{{status_code}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": {"mode": "normal"}}}}},
      {"id": 12, "title": "📊 Resource Saturation", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %", "refId": "A"}, {"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "Memory %", "refId": "B"}], "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}}}}
    ]
  },
  "overwrite": true
