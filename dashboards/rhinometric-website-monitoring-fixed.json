{
  "dashboard": {
    "id": null,
    "title": "Rhinometric Website Monitoring",
    "tags": ["rhinometric", "website", "monitoring"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Website Status",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_success{instance=\"https://www.rhinometric.com/\"}",
          "instant": true,
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ],
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "center"
        }
      },
      {
        "id": 2,
        "title": "HTTP Status Code",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_http_status_code{instance=\"https://www.rhinometric.com/\"}",
          "instant": true,
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "mappings": [
              {"options": {"200": {"text": "200 OK", "color": "green"}}, "type": "value"},
              {"options": {"404": {"text": "404 Not Found", "color": "red"}}, "type": "value"},
              {"options": {"500": {"text": "500 Error", "color": "red"}}, "type": "value"}
            ],
            "thresholds": {
              "steps": [
                {"color": "green", "value": 200},
                {"color": "yellow", "value": 300},
                {"color": "red", "value": 400}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Response Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_http_duration_seconds{instance=\"https://www.rhinometric.com/\"}",
          "refId": "A",
          "legendFormat": "Response Time"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 0.1, "gradientMode": "none", "showPoints": "auto", "pointSize": 5},
            "unit": "s"
          }
        },
        "options": {
          "tooltip": {"mode": "single", "sort": "none"},
          "legend": {"displayMode": "visible"}
        }
      },
      {
        "id": 4,
        "title": "DNS Lookup Time",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_dns_lookup_time_seconds{instance=\"https://www.rhinometric.com/\"}",
          "instant": true,
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.1},
                {"color": "red", "value": 0.5}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "SSL Certificate Expiry",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 32},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "(probe_ssl_earliest_cert_expiry{instance=\"https://www.rhinometric.com/\"} - time()) / 86400",
          "instant": true,
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "days",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 7},
                {"color": "green", "value": 30}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Content Length",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_http_content_length{instance=\"https://www.rhinometric.com/\"}",
          "instant": true,
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "bytes"
          }
        }
      },
      {
        "id": 7,
        "title": "HTTP Version",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 48},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_http_version{instance=\"https://www.rhinometric.com/\"}",
          "instant": true,
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "mappings": [
              {"options": {"1.1": {"text": "HTTP/1.1", "color": "yellow"}}, "type": "value"},
              {"options": {"2": {"text": "HTTP/2", "color": "green"}}, "type": "value"}
            ]
          }
        }
      },
      {
        "id": 8,
        "title": "Total Probe Duration",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 56},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_duration_seconds{instance=\"https://www.rhinometric.com/\"}",
          "refId": "A",
          "legendFormat": "Total Probe Time"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 0.1},
            "unit": "s"
          }
        }
      },
      {
        "id": 9,
        "title": "Uptime Percentage (24h)",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 64},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "avg_over_time(probe_success{instance=\"https://www.rhinometric.com/\"}[24h]) * 100",
          "instant": true,
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 95},
                {"color": "green", "value": 99}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Website Availability Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 72},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "rate(probe_success{instance=\"https://www.rhinometric.com/\"}[1h])",
          "instant": true,
          "refId": "A"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0.95},
                {"color": "yellow", "value": 0.99},
                {"color": "green", "value": 1.0}
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Response Time Trend",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 80},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "avg_over_time(probe_http_duration_seconds{instance=\"https://www.rhinometric.com/\"}[5m])",
          "refId": "A",
          "legendFormat": "Avg Response Time"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 0.2},
            "unit": "s"
          }
        }
      },
      {
        "id": 12,
        "title": "Availability Status",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 88},
        "targets": [{
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_success{instance=\"https://www.rhinometric.com/\"}",
          "refId": "A",
          "legendFormat": "Website Available"
        }],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 0.3},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            },
            "min": 0,
            "max": 1
          }
        }
      }
    ]
  },
  "message": "Rhinometric Website Monitoring Dashboard - Fixed Metrics",
  "overwrite": true
}
