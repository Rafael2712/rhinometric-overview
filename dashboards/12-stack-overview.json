{
  "dashboard": {
    "title": "📊 Full Stack - Overview",
    "tags": ["stack", "overview", "complete", "enterprise"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {"id": 1, "title": "🎯 All Services Status", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "count(up == 1)", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "none", "colorMode": "value", "textMode": "value_and_name"}},
      {"id": 2, "title": "💾 Total Memory Used", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(container_memory_usage_bytes{name=~\".+\"})", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 3, "title": "💻 Total CPU Usage", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(rate(container_cpu_usage_seconds_total{name=~\".+\"}[5m])) * 100", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 4, "title": "📈 Total Traces", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(tempodb_backend_objects_total)", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 5, "title": "🎯 Services Health", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "up", "legendFormat": "{{job}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 50, "stacking": {"mode": "normal"}}}}},
      {"id": 6, "title": "💾 Memory by Service", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "topk(10, container_memory_usage_bytes{name=~\".+\"})", "legendFormat": "{{name}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}}}},
      {"id": 7, "title": "📝 Log Volume", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14}, "datasource": {"type": "loki", "uid": "df1lwsdy0ecqof"}, "targets": [{"expr": "sum by (service_name) (rate({service_name=~\".+\"}[5m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "logs/s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}}}},
      {"id": 8, "title": "🔍 Trace Ingestion", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "sum(rate(tempo_request_message_bytes_count[5m])) by (route)", "legendFormat": "{{route}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": {"mode": "normal"}}}}},
      {"id": 9, "title": "🗄️ Database Health", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 0, "y": 22}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "pg_database_size_bytes", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 10, "title": "⚡ Redis Health", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 6, "y": 22}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "redis_connected_clients", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}}, "options": {"graphMode": "area", "colorMode": "value"}},
      {"id": 11, "title": "🌐 Nginx Status", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 12, "y": 22}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "up{job=\"blackbox\"}", "refId": "A"}], "fieldConfig": {"defaults": {"mappings": [{"type": "value", "value": 0, "text": "DOWN", "color": "red"}, {"type": "value", "value": 1, "text": "UP", "color": "green"}], "color": {"mode": "thresholds"}}}, "options": {"graphMode": "none", "colorMode": "background"}},
      {"id": 12, "title": "📊 Prometheus Health", "type": "stat", "gridPos": {"h": 6, "w": 6, "x": 18, "y": 22}, "datasource": {"type": "prometheus", "uid": "ff1lws6mz39xcc"}, "targets": [{"expr": "up{job=\"prometheus\"}", "refId": "A"}], "fieldConfig": {"defaults": {"mappings": [{"type": "value", "value": 0, "text": "DOWN", "color": "red"}, {"type": "value", "value": 1, "text": "UP", "color": "green"}], "color": {"mode": "thresholds"}}}, "options": {"graphMode": "none", "colorMode": "background"}}
    ]
  },
  "overwrite": true
}
