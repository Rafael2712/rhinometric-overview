{
  "name": "rhinometric-saas-api",
  "version": "1.0.0",
  "description": "RhinoMetric SaaS Platform API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "migrate": "node migrations/migrate.js",
    "seed": "node migrations/seeds.js",
    "rollback": "node migrations/rollback.js",
    "db:reset": "npm run rollback && npm run migrate && npm run seed"
  },
  "keywords": [
    "saas",
    "rhinometric",
    "api",
    "multi-tenant"
  ],
  "author": "Rafael Canelón",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^10.0.0",
    "express": "^4.17.3",
    "express-rate-limit": "^5.5.1",
    "helmet": "^4.6.0",
    "joi": "^17.6.0",
    "jsonwebtoken": "^8.5.1",
    "pg": "^7.18.2",
    "prom-client": "^15.1.3",
    "redis": "^3.1.2",
    "response-time": "^2.3.4",
    "uuid": "^8.3.2",
    "winston": "^3.3.3"
  },
  "devDependencies": {
    "eslint": "^8.11.0",
    "jest": "^27.5.1",
    "nodemon": "^2.0.15",
    "supertest": "^6.2.2"
  },
  "engines": {
    "node": ">=10.24.0"
  }
}
