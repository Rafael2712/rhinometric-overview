# ──────────────────────────────────────────────────────────────
# Rhinometric Collector — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Get your service key and telemetry token from:
#   Rhinometric Console > Services > [your service] > Telemetry Setup
# ──────────────────────────────────────────────────────────────

# REQUIRED — Rhinometric API base URL (no trailing slash)
RHYNO_API_URL=http://your-rhinometric-host/api

# REQUIRED — Service key (identifies which service this collector reports for)
RHYNO_SERVICE_KEY=your-service-key

# REQUIRED — Telemetry token (authenticates this collector)
RHYNO_TELEMETRY_TOKEN=your-telemetry-token

# ──────────────────────────────────────────────────────────────
# OPTIONAL — Override defaults below only if needed
# ──────────────────────────────────────────────────────────────

# Collection interval in seconds (minimum: 5)
# COLLECT_INTERVAL=15

# Enable/disable individual signals (true/false)
# ENABLE_METRICS=true
# ENABLE_LOGS=true
# ENABLE_TRACES=true

# Log verbosity: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Environment tag attached to all telemetry data
# RHYNO_ENVIRONMENT=production

# ──────────────────────────────────────────────────────────────
# FILE-BASED LOG INGESTION (Task 21 — v1.2.0)
# ──────────────────────────────────────────────────────────────
# Comma-separated list of log files to tail.
# Each path can optionally be prefixed with "file:".
# Leave empty or omit to only send internal collector logs.
#
# Examples:
#   LOG_SOURCES=file:/var/log/app.log,file:/var/log/syslog
#   LOG_SOURCES=/var/log/myapp/output.log
# LOG_SOURCES=

# Maximum number of lines to read per file per cycle (default: 50)
# LOG_MAX_LINES=50

# Minimum interval in seconds between file reads (default: 5)
# LOG_POLL_INTERVAL=5
