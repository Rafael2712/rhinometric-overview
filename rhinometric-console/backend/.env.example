# ============================================
# RHINOMETRIC CONSOLE - ENVIRONMENT VARIABLES
# ============================================
# 
# SECURITY WARNING: This is a template file.
# DO NOT commit .env with real credentials to version control.
# Copy this file to .env and customize values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#
# ============================================

# ============================================
# AUTHENTICATION
# ============================================
# CRITICAL: Change these in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# JWT Secret Key (MUST be at least 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS_REQUIRED

# ============================================
# API CONFIGURATION
# ============================================
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3002","http://127.0.0.1:3002"]

# ============================================
# EXTERNAL SERVICES
# ============================================
PROMETHEUS_URL=http://localhost:9090
AI_ANOMALY_URL=http://localhost:8085
LICENSE_VALIDATOR_URL=http://localhost:8091
ALERTMANAGER_URL=http://localhost:9093
GRAFANA_URL=http://localhost:3000
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686

# ============================================
# DATABASE (if applicable in future)
# ============================================
# DB_PASSWORD=your_secure_database_password
# POSTGRES_PASSWORD=your_secure_postgres_password
