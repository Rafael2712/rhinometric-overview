# Rhinometric Console Backend - Environment Variables Example
# Copia este archivo como .env y configura tus valores reales

# Database Configuration
DATABASE_URL=postgresql://rhinometric:your_db_password@postgres:5432/rhinometric

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Bootstrap (cambiar en primer deploy)
RHINO_ADMIN_USER=admin
RHINO_ADMIN_PASSWORD=change-this-password-immediately

# API Configuration
API_PREFIX=/api

# Service URLs
PROMETHEUS_URL=http://prometheus:9090
LICENSE_VALIDATOR_URL=http://license-server-v2:5000

# Email Configuration (SMTP)
# Para Zoho Mail Europe (smtp.zoho.eu), Gmail (smtp.gmail.com), etc.
MAIL_USERNAME=tu-email@dominio.com
MAIL_PASSWORD=tu-app-password-aqui
MAIL_FROM=tu-email@dominio.com
MAIL_PORT=587
MAIL_SERVER=smtp.zoho.eu
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
MAIL_FROM_NAME=Rhinometric Platform

# Frontend URL (para enlaces en emails)
FRONTEND_URL=http://console.rhinometric.com

# Rate Limiting
RATE_LIMIT_FORGOT_PASSWORD=3/hour

# Loki URL (para audit logs)
LOKI_URL=http://loki:3100

# Logging
LOG_LEVEL=INFO
