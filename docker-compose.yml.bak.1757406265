version: "3.9"

services:
  prometheus:
    image: prom/prometheus:v2.54.1
    container_name: mi-proyecto-prometheus
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --web.enable-lifecycle
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time=7d
    ports:
      - "127.0.0.1:9090:9090"
    volumes:
      - ./monitoring/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./monitoring/prometheus/rules:/etc/prometheus/rules:ro
      - prometheus-data:/prometheus
    networks:
      - observabilidad
    restart: unless-stopped

  alertmanager:
    image: prom/alertmanager:v0.27.0
    container_name: mi-proyecto-alertmanager
    command:
      - --config.file=/etc/alertmanager/alertmanager.yml
    ports:
      - "127.0.0.1:9093:9093"
    volumes:
      - ./monitoring/alertmanager/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro
    networks:
      - observabilidad
    restart: unless-stopped

  loki:
    image: grafana/loki:2.9.6
    container_name: mi-proyecto-loki
    command: -config.file=/etc/loki/config.yml
    ports:
      - "127.0.0.1:3100:3100"
    volumes:
      - ./monitoring/loki/config.yml:/etc/loki/config.yml:ro
      - loki-data:/loki
    networks:
      - observabilidad
    restart: unless-stopped

  promtail:
    image: grafana/promtail:2.9.6
    container_name: mi-proyecto-promtail
    command: -config.file=/etc/promtail/config.yml
    volumes:
      - ./monitoring/promtail/config.yml:/etc/promtail/config.yml:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/log:/var/log:ro
    networks:
      - observabilidad
    restart: unless-stopped

  grafana:
    image: grafana/grafana-oss:10.4.5
    container_name: mi-proyecto-grafana
    user: "472:0" # para escribir en /var/lib/grafana sin líos de permisos
    environment:
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD=admin
      - GF_USERS_ALLOW_SIGN_UP=false
    ports:
      - "127.0.0.1:3000:3000"
    volumes:
      - grafana-data:/var/lib/grafana
      # Si luego quieres provisioning, lo añadimos; por ahora lo quitamos para evitar "permission denied" en WSL.
    networks:
      - observabilidad
    restart: unless-stopped

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.47.2
    container_name: mi-proyecto-cadvisor
    ports:
      - "127.0.0.1:8080:8080"
    privileged: true
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /dev/disk/:/dev/disk:ro
    networks:
      - observabilidad
    restart: unless-stopped

  mailhog:
    image: mailhog/mailhog:v1.0.1
    container_name: mi-proyecto-mailhog
    ports:
      - "127.0.0.1:8025:8025"
    networks:
      - observabilidad
    restart: unless-stopped

networks:
  observabilidad:
    driver: bridge

volumes:
  grafana-data:
  prometheus-data:
  loki-data:
