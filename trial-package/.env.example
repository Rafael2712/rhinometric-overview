# ════════════════════════════════════════════════════════════════
# RHINOMETRIC TRIAL - VARIABLES DE ENTORNO
# Plantilla - Copiar a .env y personalizar
# ════════════════════════════════════════════════════════════════

# Base de datos PostgreSQL
POSTGRES_DB=rhinometric
POSTGRES_USER=rhinometric
POSTGRES_PASSWORD=CAMBIAR_ESTO_PASSWORD_SEGURO

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=CAMBIAR_ESTO_PASSWORD_ADMIN

# Sistema de licencias
JWT_SECRET=CAMBIAR_ESTO_SECRET_LARGO_Y_ALEATORIO

# Configuración adicional
TZ=America/New_York
COMPOSE_PROJECT_NAME=rhinometric-trial

# ════════════════════════════════════════════════════════════════
# IMPORTANTE: 
# - NO compartir este archivo
# - Usar contraseñas seguras
# - El script start-trial.sh genera esto automáticamente
# ════════════════════════════════════════════════════════════════
