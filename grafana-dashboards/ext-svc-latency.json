      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ms",
          "noValue": "No data"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "service_name"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Service Details \u2192",
                    "url": "/d/ext-svc-detail?var-service_name=${__value.text}&${__url_time_range}",
                    "targetBlank": false
