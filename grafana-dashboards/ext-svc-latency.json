    {
      "id": 4,
      "title": "Services Above 1s Latency",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(external_service_latency_ms > 1000) OR on() vector(0)",
