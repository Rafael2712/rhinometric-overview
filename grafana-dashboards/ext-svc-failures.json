{
  "uid": "ext-svc-failures",
  "title": "External Services Failure Analysis",
  "tags": [
    "external-services",
    "rhinometric",
    "failures"
  ],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Services With Active Failures",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(external_service_consecutive_failures > 0) OR on() vector(0)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "noValue": "0",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "None \u2705",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "description": "Number of services with at least one consecutive failure."
    },
    {
      "id": 2,
      "title": "Total Consecutive Failures",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(external_service_consecutive_failures) OR on() vector(0)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          },
          "noValue": "0",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "None \u2705",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "description": "Sum of all consecutive failures across services."
    },
    {
      "id": 3,
      "title": "Fleet Failure Rate",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(external_service_checks_total{result=\"failure\"}[5m])) / sum(rate(external_service_checks_total[5m])) * 100 OR on() vector(0)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          },
          "unit": "percent",
          "noValue": "0%",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "description": "Percentage of failed checks across all services in the last 5 min."
    },
    {
      "id": 4,
      "title": "Recent Incidents (24h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(external_service_incidents_total[24h])) OR on() vector(0)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "noValue": "0",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "None \u2705",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "description": "Total incidents in the last 24 hours."
    },
    {
      "id": 5,
      "title": "Top Failing Services",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, external_service_consecutive_failures > 0)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "noValue": "No active failures \u2705",
          "links": [
            {
              "title": "View Service Details \u2192",
              "url": "/d/ext-svc-detail?var-service_name=${__field.labels.service_name}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal"
      },
      "description": "Top 10 services ranked by consecutive failures."
    },
    {
      "id": 6,
      "title": "Failure Rate by Service",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, rate(external_service_checks_total{result=\"failure\"}[5m]) / rate(external_service_checks_total[5m]) * 100)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percent",
          "noValue": "No failures detected \u2705"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "service_name"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Service Details \u2192",
                    "url": "/d/ext-svc-detail?var-service_name=${__value.text}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {},
      "description": "Top 10 services by failure rate percentage (failures / total checks)."
    },
    {
      "id": 7,
      "title": "Consecutive Failures Over Time",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(5, external_service_consecutive_failures)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "description": "Consecutive failures trend for the top 5 most-affected services."
    },
    {
      "id": 8,
      "title": "Failure Check Rate Over Time",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(5, rate(external_service_checks_total{result=\"failure\"}[5m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "description": "Rate of failed checks per second for the top 5 failing services."
    },
    {
      "id": 9,
      "title": "Success Check Rate Over Time",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(5, rate(external_service_checks_total{result=\"success\"}[5m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "description": "Rate of successful checks per second for the top 5 services."
    },
    {
      "id": 10,
      "title": "Incident Volume Over Time",
      "type": "barchart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(external_service_incidents_total[1h]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {},
      "description": "Hourly incident count \u2014 useful for spotting failure spikes."
    },
    {
      "id": 11,
      "title": "Services With Repeated Failures (>1)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "external_service_consecutive_failures > 1",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "noValue": "No repeated failures \u2705"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "service_name"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Service Details \u2192",
                    "url": "/d/ext-svc-detail?var-service_name=${__value.text}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {},
      "description": "Services where failures have repeated (>1 consecutive). Indicates persistent problems."
    },
    {
      "id": 12,
      "title": "Health Score of Failing Services",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "external_service_health_score and (external_service_consecutive_failures > 0)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "unit": "percent",
          "noValue": "All services healthy \u2705",
          "links": [
            {
              "title": "View Service Details \u2192",
              "url": "/d/ext-svc-detail?var-service_name=${__field.labels.service_name}&${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal"
      },
      "description": "Health scores only for services that currently have consecutive failures."
    }
