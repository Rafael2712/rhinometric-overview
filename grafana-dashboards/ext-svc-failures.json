          "instant": true,
          "legendFormat": "{{service_name}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Total Consecutive Failures",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Ratio of failed checks to total checks across all services",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "noValue": "0%",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
