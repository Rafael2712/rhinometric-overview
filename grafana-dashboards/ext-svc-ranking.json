        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "description": "Average current latency across all services."
    },
    {
      "id": 4,
      "title": "Services Monitored",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
