        "defaults": {
          "max": 100,
          "min": 0,
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "unit": "percent"
