      "targets": [
        {
          "expr": "external_service_health_score",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{service_name}}"
        },
        {
          "expr": "avg_over_time(external_service_up[$__range]) * 100",
          "datasource": {
