        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "text": "None \u2705"
                }
              },
              "type": "value"
            }
          ],
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
