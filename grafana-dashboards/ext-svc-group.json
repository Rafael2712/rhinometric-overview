            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "count(external_service_up{group_name=\"$group_name\", service_type=~\"$service_type\"} == 0) OR on() vector(0)",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "B"
        }
      ],
      "title": "Services DOWN",
      "type": "stat"
    },
    {
