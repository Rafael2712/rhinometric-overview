        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(external_service_latency_seconds_bucket{group_name=\"$group_name\", service_type=~\"$service_type\"}[5m])) by (le)) * 1000",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "D"
        }
      ],
      "title": "Latency P95",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Average uptime percentage for services in this group.",
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
