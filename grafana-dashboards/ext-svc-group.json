        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg(avg_over_time(external_service_up{group_name=\"$group_name\", service_type=~\"$service_type\"}[$__range])) * 100 and on(service_name, service_type, group_name) external_service_up",
