              "mode": "palette-classic"
            }
          }
        }
      },
      {
        "id": 17,
        "type": "stat",
        "title": "Active Users",
        "gridPos": {
          "x": 3,
          "y": 37,
          "w": 3,
          "h": 4
        },
        "targets": [
          {
            "expr": "count(count by (user) (http_requests_total{job=\"dashboard-builder\"}))",
            "refId": "A"
