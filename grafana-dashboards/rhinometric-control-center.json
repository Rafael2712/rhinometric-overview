      {
        "id": 18,
        "type": "row",
        "title": "📈 System Metrics",
        "gridPos": {
          "x": 0,
          "y": 45,
          "w": 24,
          "h": 1
        },
        "collapsed": false
      },
      {
        "id": 19,
        "type": "timeseries",
        "title": "Container CPU Usage",
        "gridPos": {
          "x": 0,
          "y": 46,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{name=~\"rhinometric-.*\"}[5m]) * 100",
            "legendFormat": "{{name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {
              "mode": "palette-classic"
            }
          }
        }
      },
      {
        "id": 20,
        "type": "timeseries",
        "title": "Container Memory Usage",
        "gridPos": {
          "x": 12,
          "y": 46,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "container_memory_usage_bytes{name=~\"rhinometric-.*\"} / 1024 / 1024",
            "legendFormat": "{{name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "color": {
              "mode": "palette-classic"
            }
          }
        }
      },
      {
        "id": 21,
        "type": "table",
        "title": "Container Health Status",
        "gridPos": {
          "x": 0,
          "y": 54,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "container_last_seen{name=~\"rhinometric-.*\"}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "Value": true,
                "__name__": true,
                "instance": true,
                "job": true
              },
              "renameByName": {
                "name": "Container",
                "image": "Image"
              }
            }
          }
        ]
      }
    ]
  },
  "folderId": 0,
  "overwrite": true
}
