{{ define "ai_anomaly_email.html" }}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; background-color: #f0f2f5; margin: 0; padding: 20px; }
        .container { background-color: #ffffff; border-radius: 12px; max-width: 640px; margin: 0 auto; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .header-critical { background: linear-gradient(135deg, #dc3545, #c82333); }
        .header-high { background: linear-gradient(135deg, #e67e22, #d35400); }
        .header-warning { background: linear-gradient(135deg, #f39c12, #e67e22); }
        .header-medium { background: linear-gradient(135deg, #f39c12, #e67e22); }
        .header-low { background: linear-gradient(135deg, #3498db, #2980b9); }
        .header-info { background: linear-gradient(135deg, #3498db, #2980b9); }
        .header { color: #ffffff; padding: 24px 28px; }
        .header h1 { margin: 0 0 6px 0; font-size: 20px; font-weight: 700; }
        .header p { margin: 0; font-size: 14px; opacity: 0.9; }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; text-transform: uppercase; background: rgba(255,255,255,0.25); margin-right: 8px; }
        .body-content { padding: 28px; }
        .section { margin-bottom: 24px; }
        .section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; margin: 0 0 12px 0; padding-bottom: 8px; border-bottom: 2px solid #f0f2f5; }
        .description-box { background-color: #f8f9fa; border-left: 4px solid #667eea; border-radius: 0 8px 8px 0; padding: 16px; margin-bottom: 8px; }
        .description-box p { margin: 0; font-size: 15px; color: #2d3748; line-height: 1.5; }
        .deviation { font-size: 28px; font-weight: 800; color: #dc3545; }
        .deviation-label { font-size: 12px; color: #6c757d; text-transform: uppercase; }
        .stats-row { display: flex; gap: 16px; margin-top: 12px; }
        .stat-box { flex: 1; background: #f8f9fa; border-radius: 8px; padding: 12px; text-align: center; }
        .stat-value { font-size: 18px; font-weight: 700; color: #2d3748; }
        .stat-label { font-size: 11px; color: #6c757d; text-transform: uppercase; }
        .context-table { width: 100%; border-collapse: collapse; }
        .context-table td { padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f0f2f5; }
        .context-table td:first-child { color: #6c757d; font-weight: 600; width: 140px; }
        .context-table td:last-child { color: #2d3748; }
        .actions { text-align: center; margin: 24px 0; }
        .btn { display: inline-block; padding: 12px 28px; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 14px; margin: 6px; }
        .btn-primary { background-color: #667eea; color: #ffffff !important; }
        .btn-secondary { background-color: #f8f9fa; color: #2d3748 !important; border: 2px solid #dee2e6; }
        .troubleshooting { background-color: #fff8e1; border-radius: 8px; padding: 16px; }
        .troubleshooting ol { margin: 8px 0 0 0; padding-left: 20px; }
        .troubleshooting li { font-size: 14px; color: #5d4037; margin-bottom: 6px; line-height: 1.4; }
        .footer { background-color: #f8f9fa; padding: 20px 28px; text-align: center; font-size: 12px; color: #6c757d; }
        .footer a { color: #667eea; text-decoration: none; }
    </style>
</head>
<body>
    <div class="container">
        {{ range .Alerts }}
        <!-- HEADER -->
        <div class="header header-{{ .Labels.severity }}">
            <div>
                <span class="badge">{{ .Labels.severity | toUpper }}</span>
                <span class="badge">AI ANOMALY</span>
                {{ if eq .Status "resolved" }}<span class="badge" style="background:rgba(40,167,69,0.8);">RESUELTO</span>{{ end }}
            </div>
            <h1 style="margin-top:12px;">{{ .Labels.metric_name }}</h1>
            <p>Instancia: {{ .Labels.instance }} &bull; {{ .StartsAt.Format "02 Jan 2006 15:04 UTC" }}</p>
        </div>

        <div class="body-content">
            <!-- QUE HA DETECTADO RHINOMETRIC -->
            <div class="section">
                <div class="section-title">Que ha detectado Rhinometric</div>
                <div class="description-box">
                    <p>{{ .Annotations.summary }}</p>
                </div>
                {{ if .Annotations.deviation_percent }}
                <div style="text-align:center;margin-top:16px;">
                    <div class="deviation">{{ .Annotations.deviation_percent }}%</div>
                    <div class="deviation-label">Desviacion respecto al baseline</div>
                </div>
                {{ end }}
                {{ if and .Annotations.current_value .Annotations.expected_value }}
                <!--[if mso]><table width="100%"><tr><td width="50%" valign="top"><![endif]-->
                <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:12px;">
                    <tr>
                        <td width="48%" style="background:#f8f9fa;border-radius:8px;padding:12px;text-align:center;">
                            <div style="font-size:18px;font-weight:700;color:#2d3748;">{{ .Annotations.current_value }}</div>
                            <div style="font-size:11px;color:#6c757d;text-transform:uppercase;">Valor actual</div>
                        </td>
                        <td width="4%">&nbsp;</td>
                        <td width="48%" style="background:#f8f9fa;border-radius:8px;padding:12px;text-align:center;">
                            <div style="font-size:18px;font-weight:700;color:#2d3748;">{{ .Annotations.expected_value }}</div>
                            <div style="font-size:11px;color:#6c757d;text-transform:uppercase;">Baseline esperado</div>
                        </td>
                    </tr>
                </table>
                <!--[if mso]></td></tr></table><![endif]-->
                {{ end }}
            </div>

            <!-- CONTEXTO -->
            <div class="section">
                <div class="section-title">Contexto</div>
                <table class="context-table">
                    <tr><td>Tipo</td><td>AI Anomaly</td></tr>
                    <tr><td>Alerta</td><td>{{ .Labels.alertname }}</td></tr>
                    <tr><td>Metrica</td><td>{{ .Labels.metric_name }}</td></tr>
                    <tr><td>Severidad</td><td>{{ .Labels.severity | toUpper }}</td></tr>
                    <tr><td>Estado</td><td>{{ .Status }}</td></tr>
                    <tr><td>Componente</td><td>{{ .Labels.component }}</td></tr>
                    <tr><td>Instancia</td><td>{{ .Labels.instance }}</td></tr>
                    <tr><td>Job</td><td>{{ .Labels.job }}</td></tr>
                    <tr><td>Detectado</td><td>{{ .StartsAt.Format "2006-01-02 15:04:05 UTC" }}</td></tr>
                    {{ if ne .Status "firing" }}
                    <tr><td>Resuelto</td><td>{{ .EndsAt.Format "2006-01-02 15:04:05 UTC" }}</td></tr>
                    {{ end }}
                </table>
            </div>

            <!-- ACCIONES RAPIDAS -->
            <div class="section">
                <div class="section-title">Acciones rapidas</div>
                <div class="actions">
                    <a href="https://console.rhinometric.com/anomalies" class="btn btn-primary">&#128269; Abrir en consola Rhinometric</a>
                    <a href="https://console.rhinometric.com/grafana/explore?orgId=1&left={{ "{"  }}%22datasource%22:%22victoriametrics%22,%22queries%22:[{{ "{" }}%22refId%22:%22A%22,%22expr%22:%22{{ .Labels.metric_name }}%22{{ "}" }}]{{ "}" }}" class="btn btn-secondary">&#128202; Ver metricas en Grafana</a>
                </div>
                <p style="text-align:center;font-size:11px;color:#999;">Grafana requiere permisos de ADMIN/OWNER. Si no tienes acceso, usa la consola Rhinometric.</p>
            </div>

            <!-- GUIA RAPIDA DE TROUBLESHOOTING -->
            <div class="section">
                <div class="section-title">Guia rapida de troubleshooting</div>
                <div class="troubleshooting">
                    <ol>
                    {{ if eq .Labels.metric_name "node_cpu_usage" }}
                        <li>Revisar grafica de CPU en los ultimos 30 minutos en Grafana.</li>
                        <li>Cruzar con logs de procesos principales en el nodo.</li>
                        <li>Comprobar si coincide con despliegues, backups o jobs pesados.</li>
                    {{ else if eq .Labels.metric_name "node_memory_usage" }}
                        <li>Revisar uso de RAM total y por proceso en Grafana.</li>
                        <li>Buscar OOM kills en logs del sistema.</li>
                        <li>Verificar si hay fugas de memoria en servicios recientes.</li>
                    {{ else if eq .Labels.metric_name "node_disk_usage" }}
                        <li>Verificar espacio en disco con df -h en el nodo.</li>
                        <li>Identificar directorios que crecen rapido (logs, datos).</li>
                        <li>Revisar politicas de retencion y limpieza automatica.</li>
                    {{ else if eq .Labels.metric_name "node_disk_io" }}
                        <li>Revisar metricas de IOPS, read/write bytes y latencia.</li>
                        <li>Comprobar si hay procesos con acceso intensivo a disco.</li>
                        <li>Ver espacio libre y errores en logs de sistema.</li>
                    {{ else if eq .Labels.metric_name "node_network_receive" }}
                        <li>Mirar metricas de rx_bytes, rx_packets y drops.</li>
                        <li>Revisar logs de firewall / reverse-proxy.</li>
                        <li>Verificar si coincide con campanas, pruebas de carga o escaneos.</li>
                    {{ else if eq .Labels.metric_name "node_network_transmit" }}
                        <li>Ver metricas de tx_bytes, tx_packets, errores/drops.</li>
                        <li>Revisar que servicios generan mas trafico.</li>
                        <li>Validar si hay jobs de sincronizacion o backups externos.</li>
                    {{ else if eq .Labels.metric_name "rhinometric_website_availability" }}
                        <li>Revisar HTTP status (5xx/4xx), uptime y health checks.</li>
                        <li>Mirar logs de Nginx/ingress y de la aplicacion web.</li>
                        <li>Comprobar despliegues recientes en frontend/backend.</li>
                    {{ else if eq .Labels.metric_name "rhinometric_website_response_time" }}
                        <li>Ver metricas de latencia (p95/p99) en Grafana.</li>
                        <li>Revisar CPU, memoria y GC en los servicios web.</li>
                        <li>Consultar logs de consultas lentas (DB / APIs internas).</li>
                    {{ else if eq .Labels.metric_name "rhinometric_website_ssl_expiry" }}
                        <li>Verificar fecha de vencimiento del certificado SSL.</li>
                        <li>Comprobar renovacion automatica (Let's Encrypt / proveedor).</li>
                        <li>Revisar configuracion de HTTPS en Nginx.</li>
                    {{ else if eq .Labels.metric_name "rhinometric_website_dns_time" }}
                        <li>Ver metricas de DNS lookup time.</li>
                        <li>Comprobar estado del proveedor DNS / registros.</li>
                        <li>Revisar cambios recientes en records (A/CNAME) o TTL.</li>
                    {{ else }}
                        <li>Revisar metricas de {{ .Labels.metric_name }} en Grafana.</li>
                        <li>Consultar logs del servicio afectado.</li>
                        <li>Verificar cambios recientes en infraestructura.</li>
                    {{ end }}
                    </ol>
                </div>
            </div>

            <!-- MAS INFORMACION -->
            <div class="section" style="margin-bottom:0;">
                <div class="section-title">Mas informacion</div>
                <p style="font-size:13px;color:#6c757d;">
                    Documentacion del modulo AI Anomaly:
                    <a href="https://github.com/Rafael2712/rhinometric-overview/blob/main/docs/AI_ANOMALIES_CORRELATION_MODULE.md" style="color:#667eea;">AI_ANOMALIES_CORRELATION_MODULE.md</a>
                    &bull;
                    <a href="https://github.com/Rafael2712/rhinometric-overview/blob/main/docs/ALERTING_NOTIFICATIONS_AI_ANOMALY.md" style="color:#667eea;">ALERTING_NOTIFICATIONS_AI_ANOMALY.md</a>
                </p>
            </div>
        </div>
        {{ end }}

        <!-- FOOTER -->
        <div class="footer">
            <p><strong>Rhinometric Observability Platform v2.5.2</strong></p>
            <p>Servidor: 89.167.22.228 &bull; Componente: ai-anomaly</p>
            <p style="margin-top:10px;">Recibes esta alerta porque estas suscrito a notificaciones de {{ .GroupLabels.alertname }}.<br>
            <a href="https://console.rhinometric.com">Consola Rhinometric</a> &bull;
            <a href="https://console.rhinometric.com/grafana">Grafana</a>
            </p>
        </div>
    </div>
</body>
</html>
{{ end }}
