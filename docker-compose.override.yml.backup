services:
  db:
    image: postgres:16-alpine
    container_name: mi-proyecto-db
    environment:
      POSTGRES_USER: app
      POSTGRES_PASSWORD: app123
      POSTGRES_DB: appdb
    volumes:
      - postgres-data:/var/lib/postgresql/data
    ports:
      - "127.0.0.1:5432:5432"
    networks: [observabilidad]
    restart: unless-stopped

  postgres-exporter:
    image: quay.io/prometheuscommunity/postgres-exporter:v0.15.0
    container_name: mi-proyecto-postgres-exporter
    environment:
      DATA_SOURCE_NAME: postgresql://app:app123@db:5432/appdb?sslmode=disable
    depends_on: [db]
    ports:
      - "127.0.0.1:9187:9187"
    networks: [observabilidad]
    restart: unless-stopped

  prometheus:
    volumes:
      - ./monitoring/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro

volumes:
  postgres-data:
