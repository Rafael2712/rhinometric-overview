POSTGRES_PASSWORD=
PGBOUNCER_PASSWORD=
GRAFANA_ADMIN_PASSWORD=

# ============================================================================
# RHINOMETRIC LICENSE TIER
# ============================================================================
# Define el tier de licencia para configuraciones de almacenamiento/retención
# Valores permitidos: essentials | growth | enterprise
# 
# ESSENTIALS (1-20 hosts):
#   - Prometheus: 30 días
#   - Loki: 7 días (168h)
#   - Jaeger: 3 días (72h)
#   - Disco recomendado: ≥ 200GB
#
# GROWTH (21-70 hosts):
#   - Prometheus: 30 días
#   - Loki: 5 días (120h)
#   - Jaeger: 2 días (48h)
#   - Disco recomendado: ≥ 500GB
#
# ENTERPRISE (71+ hosts):
#   - Prometheus: 15 días
#   - Loki: 3 días (72h)
#   - Jaeger: 1 día (24h)
#   - Disco recomendado: ≥ 1TB
#
RHINO_LICENSE_TIER=essentials
