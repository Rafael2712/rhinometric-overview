services:
  pgbouncer-exporter:
    image: quay.io/prometheuscommunity/pgbouncer-exporter:latest
    command:
      # DSN hacia PgBouncer (usuario/clave que ya tienes en userlist.txt)
      - --pgBouncer.connectionString=postgres://postgres:admin123@pgbouncer:6432/pgbouncer?sslmode=disable
      # ¡Muy importante! Escuchar en todas las interfaces dentro del contenedor
      - --web.listen-address=:9127
    depends_on:
      - pgbouncer
    expose:
      - "9127"
    restart: unless-stopped
