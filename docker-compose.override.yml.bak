services:
  node-exporter:
    image: prom/node-exporter:v1.8.2
    volumes: ["/:/host:ro"]
    command: ["--path.rootfs=/host"]
    pid: host
    restart: unless-stopped
    ports: ["127.0.0.1:9100:9100"]
    networks: [observabilidad]

  blackbox-exporter:
    image: prom/blackbox-exporter:v0.25.0
    restart: unless-stopped
    ports: ["127.0.0.1:9115:9115"]
    networks: [observabilidad]

  web:
    image: nginx:alpine
    restart: unless-stopped
    ports: ["127.0.0.1:8081:80"]
    volumes: ["./monitoring/nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro"]
    networks: [observabilidad]

  nginx-exporter:
    image: nginx/nginx-prometheus-exporter:0.11.0
    restart: unless-stopped
    command: ["-nginx.scrape-uri=http://web/stub_status"]
    depends_on: [web]
    ports: ["127.0.0.1:9113:9113"]
    networks: [observabilidad]
  db:
    image: postgres:16-alpine
    container_name: mi-proyecto-db
    environment:
      POSTGRES_USER: app
      POSTGRES_PASSWORD: app123
      POSTGRES_DB: appdb
    volumes:
      - postgres-data:/var/lib/postgresql/data
    ports:
      - "127.0.0.1:5432:5432"
    networks: [observabilidad]
    restart: unless-stopped

  postgres-exporter:
    image: quay.io/prometheuscommunity/postgres-exporter:v0.15.0
    container_name: mi-proyecto-postgres-exporter
    environment:
      DATA_SOURCE_NAME: postgresql://app:app123@db:5432/appdb?sslmode=disable
    depends_on: [db]
    ports:
      - "127.0.0.1:9187:9187"
    networks: [observabilidad]
    restart: unless-stopped

  prometheus:
    volumes:
      - ./monitoring/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
volumes:
  postgres-data:

  prometheus:
    volumes:
      - ./monitoring/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
