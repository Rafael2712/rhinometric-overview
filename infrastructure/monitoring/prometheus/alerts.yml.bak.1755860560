groups:
  - name: infra_basics
    rules:
      - alert: InstanceDown
        expr: up == 0
        for: 2m
        labels: { severity: critical }
        annotations:
          summary: "Target {{ $labels.job }} / {{ $labels.instance }} down"
          description: "Prometheus no puede escrapear {{ $labels.instance }} (job {{ $labels.job }}) por >2m."

      - alert: HighCPULoad
        expr: sum by (instance) (rate(container_cpu_usage_seconds_total{image!=""}[5m])) > 0.8
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "CPU > 80% por 5m en {{ $labels.instance }}"
          description: "Uso CPU agregado > 80% por 5m en {{ $labels.instance }}."

      - alert: DiskSpaceLow
        expr: (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) < 0.1
        for: 10m
        labels: { severity: warning }
        annotations:
          summary: "Disco bajo en {{ $labels.instance }}"
          description: "Menos del 10% libre en /"

  - name: nginx_postgres
    rules:
      - alert: NginxHigh5xxRate
        expr: rate(nginx_http_requests_total{status=~"5.."}[5m]) > 1
        for: 2m
        labels: { severity: critical }
        annotations:
          summary: "Errores 5xx altos en Nginx"
          description: "rate(5xx) > 1 req/s."

      - alert: PostgresTooManyConnections
        expr: pg_stat_activity_count{datname="postgres"} > 80
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "Muchas conexiones en Postgres"
          description: "Conexiones activas > 80."

  - name: uptime_http
    rules:
      - alert: HTTPDown
        expr: probe_success{job="blackbox-http"} == 0
        for: 1m
        labels: { severity: critical }
        annotations:
          summary: "HTTP caído en {{ $labels.instance }}"
          description: "Probing vía blackbox falló (module http_2xx)."
